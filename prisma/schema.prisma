generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")

}

model User {
  id              String   @id @default(uuid())
  fullName        String
  email           String   @unique
  passwordHash    String?
  profilePic      String?
  profilePicId    String?
  provider        AuthProvider

  role            Role
  isOnboarded     Boolean  @default(false)
  isActive        Boolean  @default(true)

  emailVerified   Boolean  @default(false)
  otpHash         String?
  otpExpiresAt    DateTime?
  refreshToken    String?
  resetPasswordToken   String?
  resetPasswordExpires DateTime?

  // Relations
  investorProfile  InvestorProfile?
  ideas            Idea[]              @relation("FounderIdeas")
  ideaViews        IdeaView[]          @relation("InvestorViews")
  ideaInterests    IdeaInterest[]      @relation("InvestorInterests")

  // Chat relations
  investorRooms    ChatRoom[]          @relation("InvestorRooms")
  entrepreneurRooms ChatRoom[]         @relation("EntrepreneurRooms")
  messages         Message[]
  notifications    Notification[]

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([role])
  @@index([isActive])
}

model InvestorProfile {
  id               String     @id @default(uuid())
  userId           String     @unique

  preferredStages  Stage[]
  industries       Industry[]
  minFunding       Float
  maxFunding       Float
  investmentThesis String

  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Idea {
  id            String   @id @default(uuid())
  founderId     String

  startupName   String
  pitchTitle    String
  description   String

  industry      Industry
  stage         Stage

  fundingAmount Float
  roundType     String?
  equityOffered Boolean
  region        String

  pitchDeckUrl  String?
  pitchDeckId   String?

  // Cached counters
  viewsCount        Int      @default(0)
  interestedCount   Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  founder       User            @relation("FounderIdeas", fields: [founderId], references: [id], onDelete: Cascade)
  views         IdeaView[]
  interests     IdeaInterest[]
  chatRooms     ChatRoom[]

  @@index([industry])
  @@index([fundingAmount])
  @@index([stage])
  @@index([region])
  @@index([createdAt])
  @@index([industry, fundingAmount])
  @@index([founderId])
  @@index([viewsCount])
  @@index([interestedCount])
}

model IdeaView {
  id          String   @id @default(uuid())
  ideaId      String
  investorId  String
  createdAt   DateTime @default(now())

  idea        Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  investor    User     @relation("InvestorViews", fields: [investorId], references: [id], onDelete: Cascade)

  @@unique([ideaId, investorId], name: "ideaId_investorId_view_unique")

  @@index([ideaId])
  @@index([investorId])
  @@index([createdAt])
}

model IdeaInterest {
  id          String   @id @default(uuid())
  ideaId      String
  investorId  String
  createdAt   DateTime @default(now())

  idea        Idea     @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  investor    User     @relation("InvestorInterests", fields: [investorId], references: [id], onDelete: Cascade)

  @@unique([ideaId, investorId], name: "ideaId_investorId_interest_unique")

  @@index([ideaId])
  @@index([investorId])
  @@index([createdAt])
}

model ChatRoom {
  id             String    @id @default(uuid())
  ideaId         String
  investorId     String
  entrepreneurId String
  createdAt      DateTime  @default(now())

  idea           Idea      @relation(fields: [ideaId], references: [id], onDelete: Cascade)
  investor       User      @relation("InvestorRooms", fields: [investorId], references: [id], onDelete: Cascade)
  entrepreneur   User      @relation("EntrepreneurRooms", fields: [entrepreneurId], references: [id], onDelete: Cascade)
  messages       Message[]

  // one room per investor per idea
  @@unique([ideaId, investorId], name: "ideaId_investorId_room_unique")

  @@index([investorId])
  @@index([entrepreneurId])
  @@index([ideaId])
}

model Message {
  id        String   @id @default(uuid())
  roomId    String
  senderId  String
  content   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  room      ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender    User     @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([roomId])
  @@index([senderId])
  @@index([createdAt])
  @@index([read])
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
  @@index([createdAt])
}

enum Role {
  ENTREPRENEUR
  INVESTOR
  ADMIN
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum Stage {
  IDEA_STAGE
  PROTOTYPE
  MVP
  EARLY_REVENUE
  SCALING
  SERIES_A
}

enum Industry {
  TECHNOLOGY
  HEALTHCARE
  FINTECH
  ENERGY
  AI
  ECOMMERCE
  EDTECH
}